        { "id": "g1.st.lost-pages.ch08.s001", "speaker": "finn", "textEn": "This page is empty. Mila has no clothes!", "scaffoldDe": "Diese Seite ist leer. Mila hat keine Kleidung!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "clothes", "de": "Kleidung", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch08.s002" },

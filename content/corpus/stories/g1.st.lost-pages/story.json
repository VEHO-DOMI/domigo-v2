        { "id": "g1.st.lost-pages.ch10.s005", "speaker": "finn", "textEn": "These or those? Help!", "scaffoldDe": "Diese oder jene? Hilf!", "glosses": [{ "word": "these", "de": "diese", "scope": null }, { "word": "those", "de": "jene", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u10.gi.this-that-these-those.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch10.s006" },

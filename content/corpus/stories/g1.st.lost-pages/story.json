{
  "schema": "story@1",
  "id": "g1.st.lost-pages",
  "grade": 1,
  "title": { "en": "The Lost Pages", "de": "Die verlorenen Seiten" },
  "chapters": [
    {
      "id": "g1.st.lost-pages.ch01",
      "unit": 1,
      "titleEn": "Time for School",
      "titleDe": "Zeit für die Schule",
      "scenes": [
        { "id": "g1.st.lost-pages.ch01.s001", "speaker": "finn", "textEn": "Hi! This page is empty. Our class is gone!", "scaffoldDe": "Hi! Diese Seite ist leer. Unsere Klasse ist weg!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "gone", "de": "weg", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch01.s002" },
        { "id": "g1.st.lost-pages.ch01.s002", "speaker": "finn", "textEn": "The words are lost. Can you find them?", "scaffoldDe": "Die Wörter sind verloren. Kannst du sie finden?", "glosses": [{ "word": "words", "de": "Wörter", "scope": null }, { "word": "lost", "de": "verloren", "scope": null }, { "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u01.w.pencil", "variantKey": null }], "next": "g1.st.lost-pages.ch01.s003" },
        { "id": "g1.st.lost-pages.ch01.s003", "speaker": "finn", "textEn": "Yes! A pencil! Look here.", "scaffoldDe": "Ja! Ein Bleistift! Schau her.", "glosses": [], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch01.s004" },
        { "id": "g1.st.lost-pages.ch01.s004", "speaker": "finn", "textEn": "One book, two of them? Help!", "scaffoldDe": "Ein Buch, zwei davon? Hilf!", "glosses": [{ "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u01.gi.plurals.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch01.s005" },
        { "id": "g1.st.lost-pages.ch01.s005", "speaker": "finn", "textEn": "Now the door. Is it open?", "scaffoldDe": "Jetzt die Tür. Ist sie offen?", "glosses": [], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u01.w.door", "variantKey": null }], "next": "g1.st.lost-pages.ch01.s006" },
        { "id": "g1.st.lost-pages.ch01.s006", "speaker": "finn", "textEn": "The class is back. We did it!", "scaffoldDe": "Die Klasse ist zurück. Wir haben es geschafft!", "glosses": [{ "word": "back", "de": "zurück", "scope": null }, { "word": "did", "de": "geschafft", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch01.s007" },
        { "id": "g1.st.lost-pages.ch01.s007", "speaker": "berger", "textEn": "Welcome to school! Thank you!", "scaffoldDe": "Willkommen in der Schule! Danke!", "glosses": [{ "word": "welcome", "de": "willkommen", "scope": null }, { "word": "thank", "de": "danke", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch01.s008" },
        { "id": "g1.st.lost-pages.ch01.s008", "speaker": "finn", "textEn": "The page is full. Next room!", "scaffoldDe": "Die Seite ist voll. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "full", "de": "voll", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch02",
      "unit": 2,
      "titleEn": "At the Zoo",
      "titleDe": "Im Zoo",
      "scenes": [
        { "id": "g1.st.lost-pages.ch02.s001", "speaker": "finn", "textEn": "This page is empty. The zoo is gone!", "scaffoldDe": "Diese Seite ist leer. Der Zoo ist weg!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "gone", "de": "weg", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch02.s002" },
        { "id": "g1.st.lost-pages.ch02.s002", "speaker": "finn", "textEn": "The animals are lost. Find this one!", "scaffoldDe": "Die Tiere sind verloren. Finde dieses!", "glosses": [{ "word": "animals", "de": "Tiere", "scope": null }, { "word": "lost", "de": "verloren", "scope": null }, { "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u02.w.lion", "variantKey": null }], "next": "g1.st.lost-pages.ch02.s003" },
        { "id": "g1.st.lost-pages.ch02.s003", "speaker": "pixel", "textEn": "Meow! I want to see the lion!", "scaffoldDe": "Miau! Ich will den Löwen sehen!", "glosses": [{ "word": "meow", "de": "Miau", "scope": null }, { "word": "see", "de": "sehen", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch02.s004" },
        { "id": "g1.st.lost-pages.ch02.s004", "speaker": "finn", "textEn": "And this animal?", "scaffoldDe": "Und dieses Tier?", "glosses": [{ "word": "animal", "de": "Tier", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u02.w.monkey", "variantKey": null }], "next": "g1.st.lost-pages.ch02.s005" },
        { "id": "g1.st.lost-pages.ch02.s005", "speaker": "finn", "textEn": "Where do they live? Help!", "scaffoldDe": "Wo wohnen sie? Hilf!", "glosses": [{ "word": "live", "de": "wohnen", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u02.gi.there-is-are.mc.002", "variantKey": null }], "next": "g1.st.lost-pages.ch02.s006" },
        { "id": "g1.st.lost-pages.ch02.s006", "speaker": "finn", "textEn": "The zoo is full! I hear the lions.", "scaffoldDe": "Der Zoo ist voll! Ich höre die Löwen.", "glosses": [{ "word": "full", "de": "voll", "scope": null }, { "word": "hear", "de": "höre", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch02.s007" },
        { "id": "g1.st.lost-pages.ch02.s007", "speaker": "pixel", "textEn": "Meow! Thank you!", "scaffoldDe": "Miau! Danke!", "glosses": [{ "word": "meow", "de": "Miau", "scope": null }, { "word": "thank", "de": "danke", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch02.s008" },
        { "id": "g1.st.lost-pages.ch02.s008", "speaker": "finn", "textEn": "The page is back. Next room!", "scaffoldDe": "Die Seite ist zurück. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "back", "de": "zurück", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch03",
      "unit": 3,
      "titleEn": "Pirates",
      "titleDe": "Piraten",
      "scenes": [
        { "id": "g1.st.lost-pages.ch03.s001", "speaker": "finn", "textEn": "This page is empty. A pirate is here!", "scaffoldDe": "Diese Seite ist leer. Ein Pirat ist hier!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "pirate", "de": "Pirat", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch03.s002" },
        { "id": "g1.st.lost-pages.ch03.s002", "speaker": "captain", "textEn": "Help! My gold is gone!", "scaffoldDe": "Hilfe! Mein Gold ist weg!", "glosses": [{ "word": "help", "de": "Hilfe", "scope": null }, { "word": "gold", "de": "Gold", "scope": null }, { "word": "gone", "de": "weg", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch03.s003" },
        { "id": "g1.st.lost-pages.ch03.s003", "speaker": "finn", "textEn": "Find the pirate's ship!", "scaffoldDe": "Finde das Schiff des Piraten!", "glosses": [{ "word": "find", "de": "finden", "scope": null }, { "word": "pirate", "de": "Pirat", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u03.w.ship", "variantKey": null }], "next": "g1.st.lost-pages.ch03.s004" },
        { "id": "g1.st.lost-pages.ch03.s004", "speaker": "finn", "textEn": "He has a big one? Help!", "scaffoldDe": "Er hat ein großes? Hilf!", "glosses": [{ "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u03.gi.have-got.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch03.s005" },
        { "id": "g1.st.lost-pages.ch03.s005", "speaker": "finn", "textEn": "Look at his face. Find this!", "scaffoldDe": "Schau sein Gesicht an. Finde das!", "glosses": [{ "word": "face", "de": "Gesicht", "scope": null }, { "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u03.w.beard", "variantKey": null }], "next": "g1.st.lost-pages.ch03.s006" },
        { "id": "g1.st.lost-pages.ch03.s006", "speaker": "finn", "textEn": "The gold is back in the chest!", "scaffoldDe": "Das Gold ist zurück in der Truhe!", "glosses": [{ "word": "gold", "de": "Gold", "scope": null }, { "word": "back", "de": "zurück", "scope": null }, { "word": "chest", "de": "Truhe", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch03.s007" },
        { "id": "g1.st.lost-pages.ch03.s007", "speaker": "captain", "textEn": "Thank you, friend!", "scaffoldDe": "Danke, Freund!", "glosses": [{ "word": "thank", "de": "danke", "scope": null }, { "word": "friend", "de": "Freund", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch03.s008" },
        { "id": "g1.st.lost-pages.ch03.s008", "speaker": "finn", "textEn": "The page is full. Next room!", "scaffoldDe": "Die Seite ist voll. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "full", "de": "voll", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch04",
      "unit": 4,
      "titleEn": "Feelings",
      "titleDe": "Gefühle",
      "scenes": [
        { "id": "g1.st.lost-pages.ch04.s001", "speaker": "finn", "textEn": "This page is empty. Robo is sad!", "scaffoldDe": "Diese Seite ist leer. Robo ist traurig!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch04.s002" },
        { "id": "g1.st.lost-pages.ch04.s002", "speaker": "robo", "textEn": "Beep. I am sad. Or happy?", "scaffoldDe": "Piep. Ich bin traurig. Oder glücklich?", "glosses": [{ "word": "beep", "de": "Piep", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch04.s003" },
        { "id": "g1.st.lost-pages.ch04.s003", "speaker": "finn", "textEn": "Find this feeling!", "scaffoldDe": "Finde dieses Gefühl!", "glosses": [{ "word": "find", "de": "finden", "scope": null }, { "word": "feeling", "de": "Gefühl", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u04.w.happy", "variantKey": null }], "next": "g1.st.lost-pages.ch04.s004" },
        { "id": "g1.st.lost-pages.ch04.s004", "speaker": "finn", "textEn": "And this one?", "scaffoldDe": "Und dieses?", "glosses": [], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u04.w.sad", "variantKey": null }], "next": "g1.st.lost-pages.ch04.s005" },
        { "id": "g1.st.lost-pages.ch04.s005", "speaker": "finn", "textEn": "Robo is not sad. Help!", "scaffoldDe": "Robo ist nicht traurig. Hilf!", "glosses": [{ "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u04.gi.to-be-negative.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch04.s006" },
        { "id": "g1.st.lost-pages.ch04.s006", "speaker": "finn", "textEn": "Robo smiles now. He is happy!", "scaffoldDe": "Robo lächelt jetzt. Er ist glücklich!", "glosses": [{ "word": "smiles", "de": "lächelt", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch04.s007" },
        { "id": "g1.st.lost-pages.ch04.s007", "speaker": "robo", "textEn": "Beep! Happy! Thank you!", "scaffoldDe": "Piep! Glücklich! Danke!", "glosses": [{ "word": "beep", "de": "Piep", "scope": null }, { "word": "thank", "de": "danke", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch04.s008" },
        { "id": "g1.st.lost-pages.ch04.s008", "speaker": "finn", "textEn": "The page is back. Next room!", "scaffoldDe": "Die Seite ist zurück. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "back", "de": "zurück", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch05",
      "unit": 5,
      "titleEn": "Our Band",
      "titleDe": "Unsere Band",
      "scenes": [
        { "id": "g1.st.lost-pages.ch05.s001", "speaker": "finn", "textEn": "This page is empty. The band is quiet!", "scaffoldDe": "Diese Seite ist leer. Die Band ist still!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "band", "de": "Band", "scope": null }, { "word": "quiet", "de": "still", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch05.s002" },
        { "id": "g1.st.lost-pages.ch05.s002", "speaker": "anna", "textEn": "My drum is gone! Help!", "scaffoldDe": "Meine Trommel ist weg! Hilf!", "glosses": [{ "word": "drum", "de": "Trommel", "scope": null }, { "word": "gone", "de": "weg", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch05.s003" },
        { "id": "g1.st.lost-pages.ch05.s003", "speaker": "finn", "textEn": "Find Anna's drums!", "scaffoldDe": "Finde Annas Trommeln!", "glosses": [{ "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u05.w.drums", "variantKey": null }], "next": "g1.st.lost-pages.ch05.s004" },
        { "id": "g1.st.lost-pages.ch05.s004", "speaker": "finn", "textEn": "And this one?", "scaffoldDe": "Und dieses?", "glosses": [], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u05.w.guitar", "variantKey": null }], "next": "g1.st.lost-pages.ch05.s005" },
        { "id": "g1.st.lost-pages.ch05.s005", "speaker": "finn", "textEn": "What can she play? Help!", "scaffoldDe": "Was kann sie spielen? Hilf!", "glosses": [{ "word": "play", "de": "spielen", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u05.gi.can.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch05.s006" },
        { "id": "g1.st.lost-pages.ch05.s006", "speaker": "finn", "textEn": "The band plays! I can dance!", "scaffoldDe": "Die Band spielt! Ich kann tanzen!", "glosses": [{ "word": "band", "de": "Band", "scope": null }, { "word": "plays", "de": "spielt", "scope": null }, { "word": "dance", "de": "tanzen", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch05.s007" },
        { "id": "g1.st.lost-pages.ch05.s007", "speaker": "anna", "textEn": "Thank you! Let's play!", "scaffoldDe": "Danke! Lass uns spielen!", "glosses": [{ "word": "thank", "de": "danke", "scope": null }, { "word": "play", "de": "spielen", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch05.s008" },
        { "id": "g1.st.lost-pages.ch05.s008", "speaker": "finn", "textEn": "The page is full. Next room!", "scaffoldDe": "Die Seite ist voll. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "full", "de": "voll", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch06",
      "unit": 6,
      "titleEn": "Detective",
      "titleDe": "Detektiv",
      "scenes": [
        { "id": "g1.st.lost-pages.ch06.s001", "speaker": "finn", "textEn": "This page is empty. A detective lost his clues!", "scaffoldDe": "Diese Seite ist leer. Ein Detektiv hat seine Hinweise verloren!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "lost", "de": "verloren", "scope": null }, { "word": "clues", "de": "Hinweise", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch06.s002" },
        { "id": "g1.st.lost-pages.ch06.s002", "speaker": "mo", "textEn": "Where are my clues? I can't see them!", "scaffoldDe": "Wo sind meine Hinweise? Ich kann sie nicht sehen!", "glosses": [{ "word": "clues", "de": "Hinweise", "scope": null }, { "word": "see", "de": "sehen", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch06.s003" },
        { "id": "g1.st.lost-pages.ch06.s003", "speaker": "finn", "textEn": "Find the detective first!", "scaffoldDe": "Finde zuerst den Detektiv!", "glosses": [{ "word": "find", "de": "finden", "scope": null }, { "word": "first", "de": "zuerst", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u06.w.detective", "variantKey": null }], "next": "g1.st.lost-pages.ch06.s004" },
        { "id": "g1.st.lost-pages.ch06.s004", "speaker": "finn", "textEn": "And his office. Find it!", "scaffoldDe": "Und sein Büro. Finde es!", "glosses": [{ "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u06.w.office", "variantKey": null }], "next": "g1.st.lost-pages.ch06.s005" },
        { "id": "g1.st.lost-pages.ch06.s005", "speaker": "finn", "textEn": "He looks for clues. Help him!", "scaffoldDe": "Er sucht nach Hinweisen. Hilf ihm!", "glosses": [{ "word": "looks", "de": "sucht", "scope": null }, { "word": "clues", "de": "Hinweise", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u06.gi.present-simple.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch06.s006" },
        { "id": "g1.st.lost-pages.ch06.s006", "speaker": "finn", "textEn": "Case closed! The clues are back.", "scaffoldDe": "Fall gelöst! Die Hinweise sind zurück.", "glosses": [{ "word": "case", "de": "Fall", "scope": null }, { "word": "closed", "de": "gelöst", "scope": null }, { "word": "clues", "de": "Hinweise", "scope": null }, { "word": "back", "de": "zurück", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch06.s007" },
        { "id": "g1.st.lost-pages.ch06.s007", "speaker": "mo", "textEn": "Thank you! Good work!", "scaffoldDe": "Danke! Gute Arbeit!", "glosses": [{ "word": "thank", "de": "danke", "scope": null }, { "word": "work", "de": "Arbeit", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch06.s008" },
        { "id": "g1.st.lost-pages.ch06.s008", "speaker": "finn", "textEn": "The page is full. Next room!", "scaffoldDe": "Die Seite ist voll. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "full", "de": "voll", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }
      ]
    },
    {
      "id": "g1.st.lost-pages.ch07",
      "unit": 7,
      "titleEn": "Noodles",
      "titleDe": "Nudeln",
      "scenes": [
        { "id": "g1.st.lost-pages.ch07.s001", "speaker": "finn", "textEn": "This page is empty. Chef Luca can't cook!", "scaffoldDe": "Diese Seite ist leer. Chef Luca kann nicht kochen!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "cook", "de": "kochen", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch07.s002" },
        { "id": "g1.st.lost-pages.ch07.s002", "speaker": "luca", "textEn": "My recipe is gone! Help!", "scaffoldDe": "Mein Rezept ist weg! Hilfe!", "glosses": [{ "word": "recipe", "de": "Rezept", "scope": null }, { "word": "gone", "de": "weg", "scope": null }, { "word": "help", "de": "Hilfe", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch07.s003" },
        { "id": "g1.st.lost-pages.ch07.s003", "speaker": "finn", "textEn": "Find the cheese!", "scaffoldDe": "Finde den Käse!", "glosses": [{ "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u07.w.cheese", "variantKey": null }], "next": "g1.st.lost-pages.ch07.s004" },
        { "id": "g1.st.lost-pages.ch07.s004", "speaker": "finn", "textEn": "And the bread. Find it!", "scaffoldDe": "Und das Brot. Finde es!", "glosses": [{ "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u07.w.bread", "variantKey": null }], "next": "g1.st.lost-pages.ch07.s005" },
        { "id": "g1.st.lost-pages.ch07.s005", "speaker": "finn", "textEn": "What does he eat? Help!", "scaffoldDe": "Was isst er? Hilf!", "glosses": [{ "word": "eat", "de": "essen", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u07.gi.adverbs-frequency.mc.004", "variantKey": null }], "next": "g1.st.lost-pages.ch07.s006" },
        { "id": "g1.st.lost-pages.ch07.s006", "speaker": "finn", "textEn": "The soup is back! It smells good.", "scaffoldDe": "Die Suppe ist zurück! Sie riecht gut.", "glosses": [{ "word": "soup", "de": "Suppe", "scope": null }, { "word": "back", "de": "zurück", "scope": null }, { "word": "smells", "de": "riecht", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch07.s007" },
        { "id": "g1.st.lost-pages.ch07.s007", "speaker": "luca", "textEn": "So good! Thank you!", "scaffoldDe": "So gut! Danke!", "glosses": [{ "word": "thank", "de": "danke", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch07.s008" },
        { "id": "g1.st.lost-pages.ch07.s008", "speaker": "finn", "textEn": "The page is full. Next room!", "scaffoldDe": "Die Seite ist voll. Nächster Raum!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "full", "de": "voll", "scope": null }, { "word": "next", "de": "nächster", "scope": null }, { "word": "room", "de": "Raum", "scope": null }], "audio": null, "taskSlots": [], "next": null }

        {
          "id": "g1.st.lost-pages.ch01.s002",
          "speaker": "finn",
          "textEn": "The words are not here. Can you find them?",
          "scaffoldDe": "Die Wörter sind nicht hier. Kannst du sie finden?",
          "glosses": [{ "word": "words", "de": "Wörter", "scope": null }],

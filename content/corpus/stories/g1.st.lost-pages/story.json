      "scenes": [
        { "id": "g1.st.lost-pages.ch09.s001", "speaker": "finn", "textEn": "This page is empty. The pets are lost!", "scaffoldDe": "Diese Seite ist leer. Die Haustiere sind verloren!", "glosses": [{ "word": "page", "de": "Seite", "scope": null }, { "word": "empty", "de": "leer", "scope": null }, { "word": "pets", "de": "Haustiere", "scope": null }, { "word": "lost", "de": "verloren", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch09.s002" },
        { "id": "g1.st.lost-pages.ch09.s002", "speaker": "tim", "textEn": "Where are my pets? Help!", "scaffoldDe": "Wo sind meine Haustiere? Hilfe!", "glosses": [{ "word": "pets", "de": "Haustiere", "scope": null }, { "word": "help", "de": "Hilfe", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch09.s003" },

        { "id": "g1.st.lost-pages.ch08.s005", "speaker": "finn", "textEn": "Does she wear a hat? Help!", "scaffoldDe": "Trägt sie einen Hut? Hilf!", "glosses": [{ "word": "wear", "de": "tragen", "scope": null }, { "word": "help", "de": "hilf", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u08.gi.present-simple-questions.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch08.s006" },
        { "id": "g1.st.lost-pages.ch08.s006", "speaker": "finn", "textEn": "Mila is dressed! She looks cool.", "scaffoldDe": "Mila ist angezogen! Sie sieht cool aus.", "glosses": [{ "word": "dressed", "de": "angezogen", "scope": null }, { "word": "looks", "de": "sieht aus", "scope": null }, { "word": "cool", "de": "cool", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch08.s007" },

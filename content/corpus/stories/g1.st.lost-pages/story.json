        { "id": "g1.st.lost-pages.ch09.s004", "speaker": "finn", "textEn": "And the box. Find it!", "scaffoldDe": "Und die Box. Finde sie!", "glosses": [{ "word": "find", "de": "finden", "scope": null }], "audio": null, "taskSlots": [{ "slot": "name-it", "itemId": "g1u09.w.box", "variantKey": null }], "next": "g1.st.lost-pages.ch09.s005" },
        { "id": "g1.st.lost-pages.ch09.s005", "speaker": "finn", "textEn": "I know him. Help with the words!", "scaffoldDe": "Ich kenne ihn. Hilf mit den Wörtern!", "glosses": [{ "word": "know", "de": "kenne", "scope": null }, { "word": "help", "de": "hilf", "scope": null }, { "word": "words", "de": "Wörter", "scope": null }], "audio": null, "taskSlots": [{ "slot": "fix-it", "itemId": "g1u09.gi.object-pronouns.mc.001", "variantKey": null }], "next": "g1.st.lost-pages.ch09.s006" },
        { "id": "g1.st.lost-pages.ch09.s006", "speaker": "finn", "textEn": "The pets are back! Look at them.", "scaffoldDe": "Die Haustiere sind zurück! Schau sie an.", "glosses": [{ "word": "pets", "de": "Haustiere", "scope": null }, { "word": "back", "de": "zurück", "scope": null }], "audio": null, "taskSlots": [], "next": "g1.st.lost-pages.ch09.s007" },

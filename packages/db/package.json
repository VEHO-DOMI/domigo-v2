{
  "name": "@domigo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:dry": "drizzle-kit push --strict --verbose"
  },
  "dependencies": {
    "@domigo/content-loader": "workspace:*",
    "@domigo/content-schema": "workspace:*",
    "@domigo/engine": "workspace:*",
    "@domigo/game-core": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^24",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5",
    "vitest": "^3"
  }
}

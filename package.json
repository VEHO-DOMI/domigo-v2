{
  "name": "domigo-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "build": "pnpm --filter web run build",
    "check:bundle": "node scripts/check-game-bundle.mjs",
    "check:paint-art": "node --experimental-strip-types scripts/check-paint-art.mjs",
    "check:game-tasks": "node --experimental-strip-types scripts/check-game-tasks.mjs",
    "record:paint-tape": "node --experimental-strip-types scripts/record-paint-tape.mjs",
    "content": "node packages/content-pipeline/src/content.ts",
    "audit:blind-solve": "node scripts/audit/blind-solve.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "pngjs": "^7.0.0"
  }
}

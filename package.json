{
  "name": "domigo-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "build": "pnpm --filter web run build",
    "check:bundle": "node scripts/check-game-bundle.mjs",
    "content": "node packages/content-pipeline/src/content.ts",
    "audit:blind-solve": "node scripts/audit/blind-solve.ts",
    "sandbox:migrate": "pnpm --filter @domigo/db run db:push",
    "sandbox:seed": "pnpm --filter @domigo/db exec node src/seed-sandbox.ts",
    "sandbox:dev": "pnpm --filter web exec next dev --port 3210",
    "sandbox:verify": "pnpm typecheck && pnpm test && pnpm build && pnpm check:bundle"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "pngjs": "^7.0.0"
  }
}

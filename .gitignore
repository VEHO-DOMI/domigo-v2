# deps / build output
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# env + local secrets — prod DATABASE_URL must NEVER live in this repo
.env
.env.*
!.env.example

# vercel
.vercel/

# macOS artifacts
# (no "* 2.*" iCloud-dup patterns here — this repo lives OUTSIDE iCloud, and
# such patterns swallow real files like "More 2 SB Unit 2.txt"; the pipeline's
# sibling-aware filter handles true iCloud dups at the SOURCE side instead)
.DS_Store

# NOTE: content/ (corpus, transcripts, dist artifacts) is COMMITTED by design —
# CI validates artifacts without needing iCloud sources. Do not ignore it.

# local Claude Code session tooling (launch configs etc.) — never repo state
.claude/
content/build/audit/blind-solve/cache.json

# Codex image drops: an AIRLOCK, never committed raw — only
# prep-art/sync-art (run by us) move QA'd files into public/art/
docs/art/drop/**
docs/art/drop-t/**
docs/art/drop-u/**
docs/art/drop-v/**
!docs/art/drop/**
docs/art/drop-t/**
docs/art/drop-u/**
docs/art/drop-v/**/.gitkeep

# Heavy Rayman video-study media — reference only, never shipped (screenshot task 2026-07-22)
docs/*.mp4
docs/Rayman X DomiGo Screenshots/**/_raw-frames/**
docs/Rayman X DomiGo Screenshots/**/_contact/**


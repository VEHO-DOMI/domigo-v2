# DomiGo v2 web app. Copy to .env.local (gitignored). Never commit real values.
# Prod DATABASE_URL + AUTH_SECRET are set in Vercel env (runbook-gated), never here.

# Dev Neon branch (HTTP pooler URL). The v2 tables live in the `domigo_v2` schema;
# v1's `public` is read for auth identity but never written.
DATABASE_URL=

# NextAuth v5. Generate a dev secret with: openssl rand -base64 33
AUTH_SECRET=
AUTH_URL=http://localhost:3013

# Dev identity fallback (non-prod only) for CI + verification scripts — a REAL
# migrated student + their class. Ignored entirely when VERCEL_ENV=production.
DEV_USER_ID=
DEV_CLASS_ID=

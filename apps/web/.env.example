# Smart Review backend (foundation PR). Copy to .env.local (gitignored).
# NEVER commit a production DATABASE_URL — prod DDL is runbook-gated (see README DB rules).

# Dev Neon branch (HTTP pooler URL). The v2 tables live in the `domigo_v2` schema;
# v1's `public` is never touched.
DATABASE_URL=

# Dev identity until real auth lands — a REAL migrated student + their class
# (valid v1 uuids), so a later auth'd session for that student keeps continuity.
# The dev backdoor is refused entirely when VERCEL_ENV=production.
DEV_USER_ID=
DEV_CLASS_ID=
